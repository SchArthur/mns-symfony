{% extends 'base.html.twig' %}

{% block title %}Nouvelle Candidature{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
            <h1 class="h2 mb-0">Déposer une candidature</h1>
            <a href="{{ path('candidacies') }}" class="btn btn-outline-secondary shadow-sm">
                Retour à la liste
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-4 p-md-5">

                        <h2 class="h4 text-center text-primary mb-4">Votre message</h2>

                        {{ form_start(form) }}
                        {{ form_widget(form) }}

                        <hr class="my-4 text-muted">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                Envoyer la candidature
                            </button>
                        </div>
                        {{ form_end(form) }}

                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
