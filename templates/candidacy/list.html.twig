{% extends 'base.html.twig' %}

{% block title %}Liste des Candidatures{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
            <h1 class="h2 mb-0">Liste des Candidatures</h1>
            <a href="{{ path('add_candidacy') }}" class="btn btn-primary shadow-sm">
                + Nouvelle candidature
            </a>
        </div>

        <div class="row g-4">
            {% for candidacy in candidacies %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h2 class="card-title h6 text-primary mb-0">
                                    Offre : {{ candidacy.offer.title }}
                                </h2>
                                <span class="badge bg-light text-secondary border">
                                {{ candidacy.createdAt|date('d/m/Y H:i') }}
                            </span>
                            </div>

                            <h3 class="h6 text-dark mb-3">
                                <small class="text-muted fw-normal">De :</small> {{ candidacy.user.email }}
                            </h3>

                            <p class="card-text text-muted mb-4">
                                "{{ candidacy.message }}"
                            </p>

                            <div class="mt-auto">
                                <a href="{{ path('single_candidacy', {'id': candidacy.id}) }}" class="btn btn-outline-primary btn-sm w-100">
                                    Voir le détail
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-light border border-info border-start-5 border-start-info text-center py-4" role="alert">
                        <p class="mb-0 text-muted">Aucune candidature trouvée pour le moment.</p>
                    </div>
                </div>
            {% endfor %}
        </div>

    </div>
{% endblock %}
