{% extends 'base.html.twig' %}

{% block title %}Détail de la candidature{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
            <h1 class="h2 mb-0">Détail de la candidature</h1>
            <a href="{{ path('add_candidacy') }}" class="btn btn-outline-primary shadow-sm">
                + Nouvelle candidature
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow border-0">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                        <span class="text-uppercase text-muted fw-bold small">Candidature pour l'offre :</span>
                        <span class="badge bg-light text-secondary border">
                        Déposée le {{ candidacy.createdAt|date('d/m/Y à H:i') }}
                    </span>
                    </div>

                    <div class="card-body p-4">
                        <h2 class="card-title h3 text-primary mb-4">
                            {{ candidacy.offer.title }}
                        </h2>

                        <div class="mb-4 bg-light p-3 rounded border">
                            <h3 class="h6 text-muted mb-1">Coordonnées du candidat</h3>
                            <p class="mb-0 fw-medium">{{ candidacy.user.email }}</p>
                        </div>

                        <h3 class="h6 text-muted mb-3">Message</h3>
                        <div class="p-4 border-start border-4 border-primary bg-light rounded-end mb-4">
                            <p class="card-text text-dark mb-0 fst-italic">
                                "{{ candidacy.message }}"
                            </p>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top p-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

                        <a href="{{ path('single_offer', {'id': candidacy.offer.id}) }}" class="btn btn-primary w-100 w-md-auto">
                            Voir l'offre associée
                        </a>

                        <div class="d-flex gap-2 w-100 w-md-auto">
                            <a href="{{ path('edit_candidacy', {'id': candidacy.id}) }}" class="btn btn-outline-secondary flex-grow-1">
                                Modifier
                            </a>
                            <a href="{{ path('delete_candidacy', {'id': candidacy.id}) }}" class="btn btn-outline-danger flex-grow-1" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette candidature ?');">
                                Supprimer
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>

    </div>
{% endblock %}
