{% extends 'base.html.twig' %}

{% block title %}Créer une Offre{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
            <h1 class="h2 mb-0">Créer une nouvelle offre</h1>
            <a href="{{ path('offers') }}" class="btn btn-outline-secondary shadow-sm">
                Retour à la liste
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-4 p-md-5">

                        <h2 class="h4 text-center text-primary mb-4">Informations de l'offre</h2>

                        {# Début du formulaire #}
                        {{ form_start(form) }}

                        {# Génère tous les champs (inputs, labels, erreurs) avec le style Bootstrap #}
                        {{ form_widget(form) }}

                        {# Séparateur visuel avant le bouton #}
                        <hr class="my-4 text-muted">

                        {# Bouton de soumission stylisé et prenant toute la largeur #}
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                Enregistrer l'offre
                            </button>
                        </div>

                        {{ form_end(form) }}

                    </div>
                </div>

            </div>
        </div>

    </div>
{% endblock %}
