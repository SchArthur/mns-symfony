{% extends 'base.html.twig' %}

{% block title %}Liste des Offres{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
            <h1 class="h2 mb-0">Liste des Offres</h1>
            <a href="{{ path('add_offer') }}" class="btn btn-primary shadow-sm">
                + Ajouter une offre
            </a>
        </div>

        <div class="row g-4">
            {% for offer in offers %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h2 class="card-title h5 text-dark mb-0">
                                    <a href="{{ path('single_offer', {'id': offer.id}) }}">{{ offer.title }}</a>
                                </h2>
                                <span class="badge bg-light text-secondary border">
                                {{ offer.createdAt|date('d/m/Y H:i') }}
                            </span>
                            </div>

                            <p class="card-text text-muted mb-4">
                                {{ offer.description }}
                            </p>

                            <div class="mt-auto d-flex gap-2">
                                <a href="{{ path('delete_offer', {'id': offer.id}) }}" class="btn btn-link text-danger btn-sm flex-grow-1" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette offre ?');">
                                    Supprimer
                                </a>
                                <a href="{{ path('edit_offer', {'id': offer.id}) }}" class="btn btn-outline-secondary btn-sm flex-grow-1">
                                    Modifier
                                </a>
                                <a href="{{ path('add_candidacy') }}" class="btn btn-outline-primary btn-sm flex-grow-1">
                                    Postuler
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-light border border-warning border-start-5 border-start-warning text-center py-4" role="alert">
                        <p class="mb-0 text-muted">Vous n'avez pas encore créé d'offre.</p>
                    </div>
                </div>
            {% endfor %}
        </div>

    </div>
{% endblock %}
